# Firebase Configuration
# Get these values from Firebase Console -> Project Settings
NEXT_PUBLIC_FIREBASE_API_KEY=YOUR_API_KEY_HERE
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abc123def456

# Payment Gateway (Paystack)
NEXT_PUBLIC_PAYSTACK_KEY=your_paystack_public_key_here

# Analytics (Google Analytics 4)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Email Service - Choose one of the options below
# Option 1: SendGrid (https://sendgrid.com)
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=noreply@ncdfcoop.com

# Option 2: Mailgun (https://www.mailgun.com)
MAILGUN_API_KEY=your_mailgun_api_key_here
MAILGUN_DOMAIN=mail.ncdfcoop.com

# Option 3: Firebase Email (Firebase Functions with SMTP trigger)
FIREBASE_EMAIL_SERVICE=disabled

# Error Tracking (Sentry)
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Application Settings
NEXT_PUBLIC_APP_NAME=NCDFCOOP Commerce
NEXT_PUBLIC_APP_URL=http://localhost:3000

