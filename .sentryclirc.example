# Sentry CLI Configuration
# Copy this to .sentryclirc and fill in the values from your Sentry account

[defaults]
org = 8-gigabytes
project = javascript-nextjs
url = https://sentry.io/

[auth]
token = your_sentry_auth_token_here

[dsn]
# This comes from your Sentry project settings
# https://docs.sentry.io/product/sentry-basics/dsn-explainer/
